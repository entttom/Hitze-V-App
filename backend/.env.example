PORT=3000
CRON_SECRET=replace-with-strong-secret
HITZE_MIN_LEVEL=2
HITZE_USE_STATIC_GEOSPHERE_RESPONSE=false
HITZE_STATIC_GEOSPHERE_URL=

# JSON string with project_id, client_email and private_key.
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n","client_email":"...","client_id":"..."}

REDIS_URL=redis://default:<password>@<redis-host>:6379
